<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/movieFragment">


    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.colorphone.ui.main.MainFragment"
        android:label="fragment_main"
        tools:layout="@layout/fragment_main" />
    <fragment
        android:id="@+id/movieFragment"
        android:name="com.example.colorphone.ui.main.MovieFragment"
        android:label="MovieFragment" >
        <action
            android:id="@+id/action_movieFragment_to_theatreFragment"
            app:destination="@id/theatreFragment" />
    </fragment>
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.colorphone.ui.login.LoginFragment"
        android:label="LoginFragment" />
    <fragment
        android:id="@+id/theatreFragment"
        android:name="com.example.colorphone.ui.theatre.TheatreFragment"
        android:label="TheatreFragment" >
        <argument
            android:name="movieId"
            app:argType="long" />
    </fragment>

</navigation>